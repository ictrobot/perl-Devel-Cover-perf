#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$SCRIPT_DIR/lib/runner.sh"
source "$SCRIPT_DIR/lib/compare.sh"

# Defaults
os="alma8"
dc_version="all"
dc_min=""
mode="all"
example="example"
build_only=0
jobs=1
skip_racy_structure_fixture=0
coverage=""
coverage_set=0
output_dir=""
verbose=0

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Test Devel::Cover::Optimizer across DC versions and runner modes.

Options:
  --os OS              OS target: alma8, alma9, alma10, perl-stable, perl-devel, all (default: alma8)
                       "all" runs alma* and perl-stable, but not perl-devel.
  --dc VERSION         DC version: specific version, "latest", or "all" (default: all)
  --dc-min VERSION     Minimum DC version when using --dc all (default: first in dc-versions.txt)
  --mode MODE          Mode: baseline, fork, opt, fork-opt, fork-opt-cache, all (default: all)
                       Debug modes: opt-no-walksymtable, fork-opt-no-walksymtable
  --coverage LIST      Comma-separated Devel::Cover criteria (default: runner default)
                       Example: statement,branch,condition,subroutine,pod
  --example DIR        Example dir relative to repo root (default: example)
  --build-only         Build Docker images only, don't run tests
  --jobs N             Parallel test jobs passed to prove/forkprove -jN (default: 1)
  --skip-racy-structure-fixture
                       Set DCO_SKIP_RACY_STRUCTURE_FIXTURE=1 inside test runs
  --output DIR         Output directory (default: ci/output/<timestamp>)
  -v, --verbose        Verbose output
  -h, --help           Show this help

Examples:
  $(basename "$0")                                  # run all DC versions, all modes
  $(basename "$0") --dc 1.52                        # one DC version, all modes
  $(basename "$0") --dc 1.52 --mode baseline        # single permutation
  $(basename "$0") --dc 1.52 --coverage statement,branch,condition,subroutine,pod
  $(basename "$0") --dc-min 1.44                    # DC 1.44 through latest
  $(basename "$0") --os perl-stable --dc latest     # official Perl stable image
  $(basename "$0") --os perl-devel --dc latest      # official Perl development image canary
  $(basename "$0") --build-only                     # just build images
EOF
    exit 0
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --os)         os="$2"; shift 2 ;;
        --dc)         dc_version="$2"; shift 2 ;;
        --dc-min)     dc_min="$2"; shift 2 ;;
        --mode)       mode="$2"; shift 2 ;;
        --coverage)   coverage="$2"; coverage_set=1; shift 2 ;;
        --example)    example="$2"; shift 2 ;;
        --build-only) build_only=1; shift ;;
        --jobs|-j)    jobs="$2"; shift 2 ;;
        --skip-racy-structure-fixture) skip_racy_structure_fixture=1; shift ;;
        --output)     output_dir="$2"; shift 2 ;;
        -v|--verbose) verbose=1; shift ;;
        -h|--help)    usage ;;
        *)            echo "Unknown option: $1" >&2; usage ;;
    esac
done

export DCO_SKIP_RACY_STRUCTURE_FIXTURE="$skip_racy_structure_fixture"

if (( jobs > 1 && skip_racy_structure_fixture )); then
    cat >&2 <<EOF
NOTE: --jobs > 1 is running with DCO_SKIP_RACY_STRUCTURE_FIXTURE=1.
This skips the generated-structure race fixture for a faster parallel smoke check.
Use --jobs 1 without this option for authoritative coverage equivalence checks.

EOF
elif (( jobs > 1 )); then
    cat >&2 <<EOF
WARNING: --jobs > 1 runs tests in parallel inside each mode.
Coverage comparison can fail due to stock Devel::Cover structure last-writer-wins behavior
when tests generate different structure for the same source digest concurrently.
Use --jobs 1 for authoritative coverage equivalence checks.

EOF
fi

# Resolve DC versions
dc_versions_file="$SCRIPT_DIR/dc-versions.txt"
if [[ ! -f "$dc_versions_file" ]]; then
    echo "ERROR: $dc_versions_file not found" >&2
    exit 2
fi

resolve_dc_versions() {
    if [[ "$dc_version" == "all" ]]; then
        if [[ -n "$dc_min" ]]; then
            awk -v min="$dc_min" '
                function vercmp(a, b,   sa, sb) {
                    split(a, sa, "."); split(b, sb, ".")
                    if (sa[1]+0 != sb[1]+0) return sa[1]+0 - sb[1]+0
                    return sa[2]+0 - sb[2]+0
                }
                vercmp($0, min) >= 0 { print }
            ' "$dc_versions_file"
        else
            cat "$dc_versions_file"
        fi
    elif [[ "$dc_version" == "latest" ]]; then
        tail -1 "$dc_versions_file"
    else
        echo "$dc_version"
    fi
}

resolve_modes() {
    if [[ "$mode" == "all" ]]; then
        printf '%s\n' "${ALL_MODES[@]}"
    else
        echo "$mode"
    fi
}

ALL_OS=(alma8 alma9 alma10 perl-stable)

resolve_os_list() {
    if [[ "$os" == "all" ]]; then
        printf '%s\n' "${ALL_OS[@]}"
    else
        echo "$os"
    fi
}

validate_coverage() {
    if (( ! coverage_set )); then
        return 0
    fi
    if [[ -z "$coverage" ]]; then
        echo "ERROR: --coverage cannot be empty" >&2
        exit 2
    fi
    if [[ ! "$coverage" =~ ^[[:alnum:]_,-]+$ ]]; then
        echo "ERROR: --coverage must be a comma-separated list of criteria/options" >&2
        exit 2
    fi
    case "$coverage" in
        *,|,*|*,,*)
            echo "ERROR: --coverage has an empty list entry: $coverage" >&2
            exit 2
            ;;
    esac
}

# Map OS name to Dockerfile and build args
os_dockerfile() {
    local os_name="$1"
    case "$os_name" in
        alma*) echo "$SCRIPT_DIR/docker/Dockerfile.alma" ;;
        perl-*) echo "$SCRIPT_DIR/docker/Dockerfile.perl" ;;
        *)     echo "$SCRIPT_DIR/docker/Dockerfile.${os_name}" ;;
    esac
}

os_build_args() {
    local os_name="$1"
    case "$os_name" in
        alma*) echo "--build-arg ALMA_VERSION=${os_name#alma}" ;;
        perl-stable) echo "--build-arg PERL_TAG=stable" ;;
        perl-devel)  echo "--build-arg PERL_TAG=devel" ;;
    esac
}

dc_list=$(resolve_dc_versions)
mode_list=$(resolve_modes)
os_list=$(resolve_os_list)
validate_coverage
if (( coverage_set )); then
    summary_coverage=$(summary_coverage_for "$coverage")
    if [[ -z "$summary_coverage" ]]; then
        echo "ERROR: --coverage must include at least one summary criterion: $DC_SUMMARY_COVERAGE" >&2
        exit 2
    fi
else
    summary_coverage="runner default"
fi

if [[ -z "$dc_list" ]]; then
    echo "ERROR: no DC versions selected" >&2
    exit 2
fi

# Output directory
if [[ -z "$output_dir" ]]; then
    output_dir="$SCRIPT_DIR/output/$(date +%Y%m%d-%H%M%S)"
fi
mkdir -p "$output_dir"

log() { echo "$*" >&2; }
vlog() { (( verbose )) && echo "    $*" >&2 || true; }

log "Output directory: $output_dir"
if (( coverage_set )); then
    log "Coverage criteria: $coverage"
else
    log "Coverage criteria: runner default"
fi
log "Summary criteria: $summary_coverage"
if (( skip_racy_structure_fixture )); then
    log "Skipping racy structure fixture: DCO_SKIP_RACY_STRUCTURE_FIXTURE=1"
fi

print_failure_detail() {
    local mode_dir="$1" status="$2"
    local test_output="$mode_dir/test-output.txt"
    local summary="$mode_dir/summary.txt"
    local detailed="$mode_dir/detailed.txt"
    local baseline_summary="$3"
    local baseline_detailed="${4:-}"

    log "    output: $mode_dir"
    if [[ "$status" == "FAIL(summary)" && -f "$baseline_summary" && -f "$summary" ]]; then
        log "    summary diff:"
        diff -u "$baseline_summary" "$summary" 2>&1 | sed 's/^/      /' >&2 || true
    elif [[ "$status" == "FAIL(detail)" && -f "$baseline_detailed" && -f "$detailed" ]]; then
        log "    detailed coverage diff (first 200 lines):"
        diff -u "$baseline_detailed" "$detailed" 2>&1 \
            | sed 's/^/      /' \
            | head -200 >&2 || true
    elif [[ -f "$test_output" ]]; then
        log "    test output tail:"
        tail -40 "$test_output" | sed 's/^/      /' >&2
    fi
}

read_mode_metric() {
    local mode_dir="$1" key="$2"
    local time_file="$mode_dir/time.txt"
    if [[ -f "$time_file" ]]; then
        awk -v key="$key" '
            {
                for (i = 1; i <= NF; i++) {
                    split($i, kv, "=")
                    if (kv[1] == key) {
                        print kv[2]
                        found = 1
                        exit
                    }
                }
            }
            END { if (!found) print "n/a" }
        ' "$time_file"
    else
        echo "n/a"
    fi
}

read_mode_elapsed() {
    local time_file="$1/time.txt"
    if [[ -f "$time_file" ]]; then
        local elapsed
        elapsed=$(read_mode_metric "$1" elapsed)
        if [[ "$elapsed" != "n/a" ]]; then
            echo "$elapsed"
        else
            tail -n 1 "$time_file"
        fi
    else
        echo "n/a"
    fi
}

read_mode_cpu() {
    local user sys
    user=$(read_mode_metric "$1" user)
    sys=$(read_mode_metric "$1" sys)
    if [[ "$user" == "n/a" || "$sys" == "n/a" ]]; then
        echo "n/a"
    else
        awk -v user="$user" -v sys="$sys" 'BEGIN { printf "%.2f", user + sys }'
    fi
}

read_mode_exit() {
    local exit_file="$1/exit-code.txt"
    if [[ -f "$exit_file" ]]; then
        cat "$exit_file"
    else
        echo "?"
    fi
}

total_pass=0
total_fail=0
summary_lines=()

while IFS= read -r cur_os; do
    dockerfile=$(os_dockerfile "$cur_os")
    if [[ ! -f "$dockerfile" ]]; then
        echo "ERROR: Dockerfile not found: $dockerfile" >&2
        exit 2
    fi
    build_args=$(os_build_args "$cur_os")
    image_prefix="dco-test/${cur_os}"

    # --- Phase 1: Build images (sequential to maximise layer reuse) ---
    log "Building images for ${cur_os} ($(echo "$dc_list" | wc -l | tr -d ' ') DC versions)"

    while IFS= read -r ver; do
        tag="${image_prefix}:dc-${ver}"
        log_file="${output_dir}/${cur_os}/build-dc-${ver}.log"
        mkdir -p "$(dirname "$log_file")"

        if docker build \
            --load \
            --build-arg "DC_VERSION=${ver}" \
            $build_args \
            -t "$tag" \
            -f "$dockerfile" \
            "$REPO_ROOT" > "$log_file" 2>&1; then
            vlog "built: $tag"
        else
            log "FAIL: ${cur_os} DC $ver failed to build (see $log_file)"
            exit 2
        fi
    done <<< "$dc_list"

    if (( build_only )); then
        continue
    fi

    # --- Phase 2: Run tests ---
    while IFS= read -r ver; do
        tag="${image_prefix}:dc-${ver}"
        run_dir="${output_dir}/${cur_os}/dc-${ver}/${example}"

        log "${cur_os} DC $ver: running modes (parallel)"

        mode_pids=()
        declare -A pid_mode=()
        declare -A pid_dir=()
        while IFS= read -r m; do
            mode_dir="$run_dir/$m"
            coverage_args=()
            (( coverage_set )) && coverage_args=("$coverage")
            (
                run_mode "$tag" "$m" "$example" "$mode_dir" "$REPO_ROOT" "$jobs" "${coverage_args[@]}" || \
                    echo "2" > "$mode_dir/exit-code.txt"
            ) &
            pid=$!
            mode_pids+=("$pid")
            pid_mode[$pid]="$m"
            pid_dir[$pid]="$mode_dir"
        done <<< "$mode_list"

        remaining=${#mode_pids[@]}
        while (( remaining > 0 )); do
            finished_pid=""
            wait -n -p finished_pid 2>/dev/null || true
            [[ -n "$finished_pid" ]] || break

            m="${pid_mode[$finished_pid]}"
            mode_dir="${pid_dir[$finished_pid]}"
            local_elapsed=$(read_mode_elapsed "$mode_dir")
            local_cpu=$(read_mode_cpu "$mode_dir")
            local_exit=$(read_mode_exit "$mode_dir")
            log "  $m finished: elapsed=${local_elapsed}s cpu=${local_cpu}s [exit $local_exit]"
            if [[ "$local_exit" != "0" ]]; then
                print_failure_detail "$mode_dir" "FAIL(exit $local_exit)" "$run_dir/baseline/summary.txt" "$run_dir/baseline/detailed.txt"
            fi
            remaining=$((remaining - 1))
        done

        ver_failed=0
        timing_line="${cur_os} DC $ver:"
        while IFS= read -r m; do
            mode_dir="$run_dir/$m"
            local_elapsed=$(read_mode_elapsed "$mode_dir")
            local_cpu=$(read_mode_cpu "$mode_dir")
            local_exit=$(read_mode_exit "$mode_dir")
            summary_ref=$(summary_reference "$run_dir")
            detail_ref=$(detail_reference "$run_dir" "$m")

            if [[ "$local_exit" != "0" ]]; then
                local_status="FAIL(exit $local_exit)"
                ver_failed=1
            elif [[ "$mode" != "all" || "$m" == "baseline" ]]; then
                local_status="PASS"
            else
                local_status=$(compare_mode_coverage "$run_dir" "$m")
                [[ "$local_status" == "PASS" ]] || ver_failed=1
            fi

            if is_coverage_failure "$local_status"; then
                log "  $m comparison: elapsed=${local_elapsed}s cpu=${local_cpu}s [$local_status]"
                print_failure_detail "$mode_dir" "$local_status" "$summary_ref" "$detail_ref"
            fi
            timing_line+="  $m=${local_elapsed}s[$local_status]"
        done <<< "$mode_list"
        summary_lines+=("$timing_line")

        if (( ver_failed )); then
            log "${cur_os} DC $ver: FAIL"
            total_fail=$((total_fail + 1))
        else
            log "${cur_os} DC $ver: PASS"
            total_pass=$((total_pass + 1))
        fi

    done <<< "$dc_list"
done <<< "$os_list"

# --- Summary ---
if (( build_only )); then
    log "Build-only mode, done."
    exit 0
fi

log ""
log "=== Summary ==="
for line in "${summary_lines[@]}"; do
    log "$line"
done
log ""
log "Passed: $total_pass  Failed: $total_fail"

if (( total_fail > 0 )); then
    log "RESULT: FAIL"
    exit 1
else
    log "RESULT: PASS"
    exit 0
fi
